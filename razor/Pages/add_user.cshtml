@page
@model razor.Pages.add_userModel
@{
    ViewData["Title"] = "Zaloguj się";
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Alledrogo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav>
        <a class="nav-logo" href="/">Alle<span>drogo</span></a>
        <ul class="nav-links">
            <li><a asp-page="/add_auction">Sprzedaj</a></li>
            <li><a asp-page="/register">Utwórz konto</a></li>
            <li><a asp-page="/add_user" class="nav-btn">Zaloguj</a></li>
        </ul>
    </nav>

    <section class="hero" style="padding: 60px 2rem 50px;">
        <div style="max-width:1200px; margin:0 auto;">
            <div class="hero-tag">Twoje konto</div>
            <h1>Zaloguj się</h1>
        </div>
    </section>

    <div style="max-width: 480px; margin: 50px auto; padding: 0 1.5rem 0;">
        <form method="post">
            <div class="mb-3">
                <label asp-for="Email" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Adres e-mail</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="np. jan@example.com" />
                <span asp-validation-for="Email" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Haslo" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Hasło</label>
                <input asp-for="Haslo" class="form-control" type="password" placeholder="Twoje hasło" />
                <span asp-validation-for="Haslo" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div style="display:flex; gap:1rem; flex-wrap:wrap;">
                <button type="submit" class="btn-primary-custom">Zaloguj się</button>
                <a asp-page="/Index" class="btn-outline-custom" style="display:inline-block;">Anuluj</a>
            </div>

            <p style="margin-top:1.5rem; font-size:.85rem; color:#888;">
                Nie masz konta? <a asp-page="/register" style="color:var(--orange); text-decoration:none;">Utwórz konto</a>
            </p>
        </form>
    </div>

    <footer>
        <div class="footer-inner">
            <div>
                <div class="footer-logo">Alle<span>drogo</span></div>
                <p>Profesjonalne aukcje od 1996 roku. Kupuj i sprzedawaj z pewnością.</p>
            </div>
            <div class="footer-col">
                <h5>Pomoc</h5>
                <a asp-page="/Regulamin">Regulamin</a>
                <a asp-page="/Prywatnosc">Polityka prywatności</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Alledrogo. Wszelkie prawa zastrzeżone.</span>
            <span>Warszawa, Polska</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
