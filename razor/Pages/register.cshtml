@page
@model razor.Pages.registerModel
@{
    ViewData["Title"] = "Utwórz konto";
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Alledrogo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav>
        <a class="nav-logo" href="/">Alle<span>drogo</span></a>
        <ul class="nav-links">
            <li><a asp-page="/add_auction">Licytuj</a></li>
            <li><a href="#">Sprzedaj</a></li>
            <li><a asp-page="/register">Utwórz konto</a></li>
            <li><a asp-page="/add_user" class="nav-btn">Zaloguj</a></li>
        </ul>
    </nav>

    <section class="hero" style="padding: 60px 2rem 50px;">
        <div style="max-width:1200px; margin:0 auto;">
            <div class="hero-tag">Nowe konto</div>
            <h1>Utwórz <span>konto</span></h1>
        </div>
    </section>

    <div style="max-width: 520px; margin: 50px auto; padding: 0 1.5rem 0;">
        <form method="post">
            <div class="mb-3">
                <label asp-for="Imie" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Imię</label>
                <input asp-for="Imie" class="form-control" placeholder="np. Jan" />
                <span asp-validation-for="Imie" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DrugieImie" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Drugie imię <span style="color:#aaa; font-weight:400;">(opcjonalnie)</span></label>
                <input asp-for="DrugieImie" class="form-control" placeholder="np. Marek" />
            </div>

            <div class="mb-3">
                <label asp-for="Nazwisko" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Nazwisko</label>
                <input asp-for="Nazwisko" class="form-control" placeholder="np. Kowalski" />
                <span asp-validation-for="Nazwisko" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Adres e-mail</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="np. jan@example.com" />
                <span asp-validation-for="Email" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Haslo" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Hasło</label>
                <input asp-for="Haslo" class="form-control" type="password" placeholder="Minimum 8 znaków" />
                <span asp-validation-for="Haslo" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div style="display:flex; gap:1rem; flex-wrap:wrap;">
                <button type="submit" class="btn-primary-custom">Utwórz konto</button>
                <a asp-page="/Index" class="btn-outline-custom" style="display:inline-block;">Anuluj</a>
            </div>

            <p style="margin-top:1.5rem; font-size:.85rem; color:#888;">
                Masz już konto? <a asp-page="/add_user" style="color:var(--orange); text-decoration:none;">Zaloguj się</a>
            </p>
        </form>
    </div>

    <section style="background: var(--dark); padding: 80px 2rem 60px; margin-top: 80px;"></section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
