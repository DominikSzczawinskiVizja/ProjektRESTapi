@page
@model razor.Pages.AdminModel
@{
    ViewData["Title"] = "Panel administratora";
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Alledrogo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body>
    <nav>
        <div class="nav-left">
            <a class="nav-logo" href="/">Alle<span>drogo</span></a>
        </div>
        <ul class="nav-links">
            <li><a asp-page="/add_auction">Sprzedaj</a></li>
            @if (!string.IsNullOrEmpty(Model.LoggedEmail))
            {
                <li><span style="color:#ccc; font-size:.82rem; font-weight:500; letter-spacing:.05em; text-transform:uppercase;">@Model.LoggedEmail</span></li>
                <li><a asp-page="/Profil" class="nav-btn" style="background:#333;">Profil</a></li>
                <li><a asp-page="/Logout" class="nav-btn" style="background:#333;">Wyloguj</a></li>
            }
        </ul>
    </nav>

    <div style="max-width:1100px; margin:60px auto; padding:0 1.5rem 80px;">
        <h1 style="font-family:'Bebas Neue',sans-serif; font-size:2.4rem; letter-spacing:1px; margin-bottom:.5rem;">Panel administratora</h1>
        <p style="color:#888; font-size:.9rem; margin-bottom:2rem;">Lista wszystkich zarejestrowanych użytkowników.</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div style="background:#ff4444; color:#fff; padding:.8rem 1.2rem; border-radius:6px; margin-bottom:1.5rem; font-size:.88rem; font-weight:500;">
                @Model.ErrorMessage
            </div>
        }

        @if (Model.Users.Any())
        {
            <div style="overflow-x:auto;">
                <table style="width:100%; border-collapse:collapse; font-size:.88rem;">
                    <thead>
                        <tr style="border-bottom:2px solid #111; text-align:left;">
                            <th style="padding:.8rem 1rem; font-weight:600; text-transform:uppercase; letter-spacing:.06em; font-size:.75rem; color:#999;">ID</th>
                            <th style="padding:.8rem 1rem; font-weight:600; text-transform:uppercase; letter-spacing:.06em; font-size:.75rem; color:#999;">Imię i nazwisko</th>
                            <th style="padding:.8rem 1rem; font-weight:600; text-transform:uppercase; letter-spacing:.06em; font-size:.75rem; color:#999;">E-mail</th>
                            <th style="padding:.8rem 1rem; font-weight:600; text-transform:uppercase; letter-spacing:.06em; font-size:.75rem; color:#999;">Rola</th>
                            <th style="padding:.8rem 1rem; font-weight:600; text-transform:uppercase; letter-spacing:.06em; font-size:.75rem; color:#999;">Zarejestrowany</th>
                            <th style="padding:.8rem 1rem;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr style="border-bottom:1px solid #f0f0f0;">
                                <td style="padding:.8rem 1rem; color:#bbb;">@user.Id</td>
                                <td style="padding:.8rem 1rem; font-weight:500;">
                                    @user.FirstName @user.MiddleName @user.LastName
                                </td>
                                <td style="padding:.8rem 1rem; color:#555;">@user.Email</td>
                                <td style="padding:.8rem 1rem;">
                                    <span style="background:@(user.Role == "Admin" ? "var(--orange)" : "#eee"); color:@(user.Role == "Admin" ? "#fff" : "#555"); padding:.2rem .7rem; border-radius:20px; font-size:.75rem; font-weight:600;">
                                        @user.Role
                                    </span>
                                </td>
                                <td style="padding:.8rem 1rem; color:#888;">@user.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                <td style="padding:.8rem 1rem;">
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id"
                                          onsubmit="return confirm('Usunąć użytkownika @user.Email?')">
                                        <button type="submit" style="background:none; border:1px solid #cc2222; color:#cc2222; padding:.3rem .9rem; border-radius:4px; font-size:.78rem; font-weight:600; cursor:pointer;">
                                            Usuń
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p style="margin-top:1.5rem; color:#aaa; font-size:.82rem;">Łącznie: @Model.Users.Count użytkowników</p>
        }
        else if (string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p style="color:#888;">Brak użytkowników w systemie.</p>
        }
    </div>

    <footer>
        <div class="footer-inner">
            <div>
                <div class="footer-logo">Alle<span>drogo</span></div>
                <p>Profesjonalne aukcje od 1996 roku. Kupuj i sprzedawaj z pewnością.</p>
            </div>
            <div class="footer-col">
                <h5>Pomoc</h5>
                <a asp-page="/Regulamin">Regulamin</a>
                <a asp-page="/Prywatnosc">Polityka prywatności</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Alledrogo. Wszelkie prawa zastrzeżone.</span>
            <span>Warszawa, Polska</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
