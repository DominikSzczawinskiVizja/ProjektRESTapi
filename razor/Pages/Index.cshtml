@page
@model Alledrogo.Pages.IndexModel
@{
    ViewData["Title"] = "Alledrogo";
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body>
   <!--pasek nawigacyjny na górze -->
    <nav>
        <div class="nav-left">
            <a class="nav-logo" href="/">Alle<span>drogo</span></a>
            <div class="nav-dropdown">
                <a href="#" class="nav-dropdown-toggle">Kategorie <span class="nav-caret">▾</span></a>
                <ul class="nav-dropdown-menu">
                    @foreach (var cat in Model.Categories)
                    {
                        <li><a href="#" class="dropdown-cat-link" data-category="@cat.Slug">@cat.Name</a></li>
                    }
                </ul>
            </div>
        </div>
        <ul class="nav-links">
            <li><a asp-page="/add_auction">Sprzedaj</a></li>
            @if (!string.IsNullOrEmpty(Model.LoggedEmail))
            {
                <li><a asp-page="/Profil" style="color:#ccc; font-size:.82rem; font-weight:500; letter-spacing:.05em; text-transform:uppercase; text-decoration:none;">@Model.LoggedEmail</a></li>
                @if (Model.LoggedRole == "Admin")
                {
                    <li><a asp-page="/Admin" class="nav-btn" style="background:#555;">Admin</a></li>
                }
                <li><a asp-page="/Profil" class="nav-btn" style="background:#222;">Profil</a></li>
                <li><a asp-page="/Logout" class="nav-btn" style="background:#222;">Wyloguj</a></li>
            }
            else
            {
                <li><a asp-page="/register">Utwórz konto</a></li>
                <li><a asp-page="/add_user" class="nav-btn">Zaloguj</a></li>
            }
        </ul>
    </nav>
    <section class="hero">
        <div style="max-width:1200px; margin:0 auto;">
            <div class="hero-tag">Aukcje online i na żywo</div>
            <h1>Twoje aukcje<br /><span>Twoja cena</span></h1>
            <p>Wystawiaj i licytuj na twoich zasadach</p>
        </div>
    </section>

    <!-- losowe statystyki -->
    <div class="stats-bar">
        <div class="stat">
            <span class="stat-num">@Model.ActiveAuctions</span>
            <span class="stat-label">Aktywnych aukcji</span>
        </div>
        <div class="stat">
            <span class="stat-num">100%</span>
            <span class="stat-label">Online & Na żywo</span>
        </div>
    </div>

    <!-- aukcje -->
    <section class="auctions-section" id="auctions">
        <div class="section-title">Aktualne aukcje</div>

        <div class="filter-bar">
            <button class="filter-btn active" data-category="all">Wszystkie</button>
            @foreach (var cat in Model.Categories)
            {
                <button class="filter-btn" data-category="@cat.Slug">@cat.Name</button>
            }
        </div>

        <div class="auction-grid" id="auctionGrid">
            @if (Model.Auctions.Count == 0)
            {
                <p style="color:#888; padding:2rem 0;">Brak aukcji do wyświetlenia.</p>
            }
            @foreach (var auction in Model.Auctions)
            {
                <a class="auction-card" href="/aukcja/@auction.Id" data-category="@auction.CategorySlug">
                    <div class="card-body-custom">
                        <img src="@auction.ImageUrl" alt="@auction.Title" loading="lazy" />
                        <div class="card-category">@auction.Category</div>
                        <div class="card-title-custom">@auction.Title</div>
                        <div class="card-meta">
                            <div>
                                <div class="bid-label">@(auction.IsLive ? "Aktualna oferta" : "Cena wywoławcza")</div>
                                <div class="bid-amount">@auction.CurrentBid.ToString("N0") zł</div>
                            </div>
                            <div class="time-left">
                                <div class="time-value">@auction.TimeLeft</div>
                                <div class="time-sub">@(auction.IsLive ? "Pozostało" : "Zakończona")</div>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>

    <!-- tutorial-->
    <section class="how-section" id="how">
        <div class="how-inner">
            <div class="section-label" style="color: var(--orange)">Prosty proces</div>
            <div class="section-title" style="color:#fff">Jak to działa?</div>
            <div class="steps-grid">
                @foreach (var step in Model.Steps)
                {
                    <div class="step">
                        <div class="step-num">@step.Number.ToString("D2")</div>
                        <h4>@step.Title</h4>
                        <p>@step.Description</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- stópka -->
    <footer>
        <div class="footer-inner">
            <div>
                <div class="footer-logo">Alle<span>drogo</span></div>
                <p>Profesjonalne aukcje od 1996 roku. Kupuj i sprzedawaj z pewnością.</p>
            </div>
            <div class="footer-col">
                <h5>Pomoc</h5>
                <a asp-page="/Regulamin">Regulamin</a>
                <a asp-page="/Prywatnosc">Polityka prywatności</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Alledrogo. Wszelkie prawa zastrzeżone.</span>
            <span>Warszawa, Polska</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // przyciski filtrujące
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                const category = this.dataset.category;
                document.querySelectorAll('.auction-card').forEach(card => {
                    card.style.display =
                        (category === 'all' || card.dataset.category === category) ? 'block' : 'none';
                });
            });
        });

        // dropdown kategorii w nav — klik otwiera/zamyka
        const dropdownToggle = document.querySelector('.nav-dropdown-toggle');
        const dropdownMenu = document.querySelector('.nav-dropdown-menu');
        const caret = document.querySelector('.nav-caret');
        if (dropdownToggle && dropdownMenu) {
            dropdownToggle.addEventListener('click', function (e) {
                e.preventDefault();
                const isOpen = dropdownMenu.classList.toggle('open');
                if (caret) caret.style.transform = isOpen ? 'rotate(180deg)' : '';
            });
            document.addEventListener('click', function (e) {
                if (!e.target.closest('.nav-dropdown')) {
                    dropdownMenu.classList.remove('open');
                    if (caret) caret.style.transform = '';
                }
            });
        }

        // kliknięcie kategorii w dropdownie - filtruje aukcje na stronie
        document.querySelectorAll('.dropdown-cat-link').forEach(link => {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                dropdownMenu.classList.remove('open');
                const slug = this.dataset.category;
                document.querySelectorAll('.filter-btn').forEach(btn => {
                    btn.classList.toggle('active', btn.dataset.category === slug);
                });
                document.querySelectorAll('.auction-card').forEach(card => {
                    card.style.display = card.dataset.category === slug ? 'block' : 'none';
                });
                document.getElementById('auctions')?.scrollIntoView({ behavior: 'smooth' });
            });
        });
    </script>

</body>
</html>
