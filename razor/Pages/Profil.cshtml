@page
@model razor.Pages.ProfilModel
@{
    ViewData["Title"] = "Mój profil";
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Alledrogo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body>
    <nav>
        <div class="nav-left">
            <a class="nav-logo" href="/">Alle<span>drogo</span></a>
        </div>
        <ul class="nav-links">
            <li><a asp-page="/add_auction">Sprzedaj</a></li>
            @if (!string.IsNullOrEmpty(Model.LoggedEmail))
            {
                <li><span style="color:#ccc; font-size:.82rem; font-weight:500; letter-spacing:.05em; text-transform:uppercase;">@Model.LoggedEmail</span></li>
                @if (Model.LoggedRole == "Admin")
                {
                    <li><a asp-page="/Admin" class="nav-btn" style="background:#555;">Admin</a></li>
                }
                <li><a asp-page="/Logout" class="nav-btn" style="background:#333;">Wyloguj</a></li>
            }
        </ul>
    </nav>

    <div style="max-width:900px; margin:60px auto; padding:0 1.5rem 80px;">

        <h1 style="font-family:'Bebas Neue',sans-serif; font-size:2.4rem; letter-spacing:1px; margin-bottom:2rem;">Mój profil</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div style="background:#ff4444; color:#fff; padding:.8rem 1.2rem; border-radius:6px; margin-bottom:1.5rem; font-size:.88rem; font-weight:500;">
                @Model.ErrorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div style="background:#22c55e; color:#fff; padding:.8rem 1.2rem; border-radius:6px; margin-bottom:1.5rem; font-size:.88rem; font-weight:500;">
                @Model.SuccessMessage
            </div>
        }

        <!-- dane użytkownika -->
        <div style="background:#fff; border:1px solid #e0e0e0; border-radius:10px; padding:2rem; margin-bottom:2.5rem;">
            <h2 style="font-family:'Bebas Neue',sans-serif; font-size:1.5rem; letter-spacing:1px; margin-bottom:1.5rem;">Dane osobowe</h2>
            <form method="post">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.2rem;">
                    <div>
                        <label class="form-label" style="font-size:.78rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Imię</label>
                        <input asp-for="Imie" class="form-control" />
                    </div>
                    <div>
                        <label class="form-label" style="font-size:.78rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Nazwisko</label>
                        <input asp-for="Nazwisko" class="form-control" />
                    </div>
                    <div>
                        <label class="form-label" style="font-size:.78rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Drugie imię (opcjonalnie)</label>
                        <input asp-for="DrugieImie" class="form-control" />
                    </div>
                    <div>
                        <label class="form-label" style="font-size:.78rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">E-mail</label>
                        <input asp-for="Email" type="email" class="form-control" />
                    </div>
                    <div style="grid-column:1/-1;">
                        <label class="form-label" style="font-size:.78rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Nowe hasło (zostaw puste jeśli nie chcesz zmieniać)</label>
                        <input asp-for="Haslo" type="password" class="form-control" placeholder="••••••••" />
                    </div>
                </div>
                <div style="margin-top:1.5rem;">
                    <button type="submit" class="btn-primary-custom">Zapisz zmiany</button>
                </div>
            </form>
        </div>

        <!-- moje aukcje -->
        <div style="margin-bottom:2.5rem;">
            <h2 style="font-family:'Bebas Neue',sans-serif; font-size:1.5rem; letter-spacing:1px; margin-bottom:1.2rem;">Moje aukcje</h2>

            @if (Model.MojeAukcje.Count == 0)
            {
                <p style="color:#888; font-size:.9rem;">Nie masz jeszcze żadnych aukcji. <a asp-page="/add_auction" style="color:var(--orange); text-decoration:none; font-weight:600;">Wystaw pierwszą</a></p>
            }
            else
            {
                <div style="display:grid; gap:.8rem;">
                    @foreach (var a in Model.MojeAukcje)
                    {
                        var isActive = a.EndAt > DateTime.UtcNow;
                        var timeLeft = a.EndAt - DateTime.UtcNow;
                        var timeStr  = !isActive ? "Zakończona"
                            : timeLeft.TotalDays >= 1 ? $"{(int)timeLeft.TotalDays} dni {timeLeft.Hours} godz."
                            : timeLeft.TotalHours >= 1 ? $"{(int)timeLeft.TotalHours} godz. {timeLeft.Minutes} min"
                            : $"{timeLeft.Minutes} min";

                        <div style="background:#fff; border:1px solid #e0e0e0; border-radius:8px; padding:1rem 1.4rem; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
                            <div style="flex:1; min-width:200px;">
                                <div style="font-weight:600; margin-bottom:.2rem;">@a.Name</div>
                                <div style="font-size:.78rem; color:#999; text-transform:uppercase; letter-spacing:.05em;">@a.Category</div>
                            </div>
                            <div style="text-align:center; min-width:100px;">
                                <div style="font-family:'Bebas Neue',sans-serif; font-size:1.4rem; color:var(--orange);">@a.Price.ToString("N0") zł</div>
                                <div style="font-size:.75rem; color:#bbb;">cena wywoławcza</div>
                            </div>
                            <div style="text-align:center; min-width:100px;">
                                <div style="font-size:.85rem; font-weight:500; color:@(isActive ? "#111" : "#bbb");">@timeStr</div>
                                <span style="font-size:.72rem; background:@(isActive ? "#e8f5e9" : "#f5f5f5"); color:@(isActive ? "#2e7d32" : "#999"); padding:.15rem .6rem; border-radius:20px; font-weight:600;">
                                    @(isActive ? "Aktywna" : "Zakończona")
                                </span>
                            </div>
                            <div style="display:flex; gap:.5rem;">
                                <a href="/aukcja/@a.Id" style="padding:.4rem .9rem; border:1px solid #ddd; border-radius:4px; font-size:.78rem; font-weight:600; color:#555; text-decoration:none;">Podgląd</a>
                                <a href="/edytuj-aukcje/@a.Id" style="padding:.4rem .9rem; border:1px solid var(--orange); border-radius:4px; font-size:.78rem; font-weight:600; color:var(--orange); text-decoration:none;">Edytuj</a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- strefa niebezpieczna -->
        <div style="padding-top:2rem; border-top:1px solid #eee;">
            <h3 style="font-family:'Bebas Neue',sans-serif; font-size:1.4rem; color:#cc2222; margin-bottom:.8rem;">Strefa niebezpieczna</h3>
            <p style="font-size:.88rem; color:#888; margin-bottom:1rem;">Usunięcie konta jest nieodwracalne. Wszystkie twoje aukcje zostaną usunięte.</p>
            <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Czy na pewno chcesz usunąć swoje konto? Tej operacji nie można cofnąć.')">
                <button type="submit" style="background:#cc2222; color:#fff; border:none; padding:.7rem 1.8rem; border-radius:4px; font-weight:600; font-size:.88rem; cursor:pointer;">
                    Usuń konto
                </button>
            </form>
        </div>

    </div>

    <footer>
        <div class="footer-inner">
            <div>
                <div class="footer-logo">Alle<span>drogo</span></div>
                <p>Profesjonalne aukcje od 1996 roku. Kupuj i sprzedawaj z pewnością.</p>
            </div>
            <div class="footer-col">
                <h5>Pomoc</h5>
                <a asp-page="/Regulamin">Regulamin</a>
                <a asp-page="/Prywatnosc">Polityka prywatności</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Alledrogo. Wszelkie prawa zastrzeżone.</span>
            <span>Warszawa, Polska</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
