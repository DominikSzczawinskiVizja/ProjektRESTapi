@page "/aukcja/{id:long}"
@model razor.Pages.AukcjaModel
@{
    ViewData["Title"] = Model.Aukcja?.Name ?? "Aukcja";
    var timeLeft = Model.Aukcja != null ? Model.Aukcja.EndAt - DateTime.UtcNow : TimeSpan.Zero;
    var isActive = timeLeft > TimeSpan.Zero;
    var timeStr = timeLeft <= TimeSpan.Zero ? "Zakończona"
        : timeLeft.TotalDays >= 1 ? $"{(int)timeLeft.TotalDays} dni {timeLeft.Hours} godz."
        : timeLeft.TotalHours >= 1 ? $"{(int)timeLeft.TotalHours} godz. {timeLeft.Minutes} min"
        : $"{timeLeft.Minutes} min";
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Alledrogo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body>
    <nav>
        <div class="nav-left">
            <a class="nav-logo" href="/">Alle<span>drogo</span></a>
        </div>
        <ul class="nav-links">
            <li><a asp-page="/add_auction">Sprzedaj</a></li>
            @if (!string.IsNullOrEmpty(Model.LoggedEmail))
            {
                <li><span style="color:#ccc; font-size:.82rem; font-weight:500; letter-spacing:.05em; text-transform:uppercase;">@Model.LoggedEmail</span></li>
                <li><a asp-page="/Logout" class="nav-btn" style="background:#333;">Wyloguj</a></li>
            }
            else
            {
                <li><a asp-page="/register">Utwórz konto</a></li>
                <li><a asp-page="/add_user" class="nav-btn">Zaloguj</a></li>
            }
        </ul>
    </nav>

    @if (Model.Aukcja == null)
    {
        <div style="max-width:800px; margin:80px auto; padding:0 1.5rem; text-align:center;">
            <p style="color:#888; font-size:1.1rem;">@(Model.ErrorMessage ?? "Ładowanie aukcji...")</p>
            <a asp-page="/Index" style="color:var(--orange);">Wróć do strony głównej</a>
        </div>
    }
    else
    {
        <div style="max-width:1000px; margin:60px auto; padding:0 1.5rem 80px; display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:start;">

            <!-- lewa kolumna - zdjęcie -->
            <div>
                <img src="https://images.unsplash.com/photo-1518791841217-8f162f1e1131?auto=format&fit=crop&w=600&h=450"
                     alt="@Model.Aukcja.Name"
                     style="width:100%; border-radius:8px; object-fit:cover;" />
                <div style="margin-top:1rem; padding:.6rem 1rem; background:#f5f5f5; border-radius:6px; font-size:.82rem; color:#666; text-transform:uppercase; letter-spacing:.05em; font-weight:600;">
                    @Model.Aukcja.Category
                </div>
            </div>

            <!-- prawa kolumna - szczegóły -->
            <div>
                <h1 style="font-family:'Bebas Neue',sans-serif; font-size:2.2rem; letter-spacing:1px; margin-bottom:.5rem;">@Model.Aukcja.Name</h1>

                <p style="color:#666; line-height:1.7; margin-bottom:2rem;">@Model.Aukcja.Description</p>

                <!-- cena i czas -->
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:2rem;">
                    <div style="background:#fff; border:1px solid #e0e0e0; border-radius:8px; padding:1.2rem;">
                        <div style="font-size:.75rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em; color:#999; margin-bottom:.3rem;">Aktualna oferta</div>
                        <div style="font-family:'Bebas Neue',sans-serif; font-size:2rem; color:var(--orange);">
                            @((Model.Aukcja.CurrentPrice > 0 ? Model.Aukcja.CurrentPrice : Model.Aukcja.Price).ToString("N0")) zł
                        </div>
                        <div style="font-size:.75rem; color:#bbb; margin-top:.2rem;">Cena wywoławcza: @Model.Aukcja.Price.ToString("N0") zł</div>
                    </div>
                    <div style="background:@(isActive ? "#fff" : "#f9f9f9"); border:1px solid #e0e0e0; border-radius:8px; padding:1.2rem;">
                        <div style="font-size:.75rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em; color:#999; margin-bottom:.3rem;">Pozostały czas</div>
                        <div style="font-family:'Bebas Neue',sans-serif; font-size:1.8rem; color:@(isActive ? "#111" : "#bbb");">@timeStr</div>
                        <div style="font-size:.75rem; color:#bbb; margin-top:.2rem;">Kończy: @Model.Aukcja.EndAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                </div>

                <!-- licytowanie -->
                @if (isActive)
                {
                    @if (!string.IsNullOrEmpty(Model.BidError))
                    {
                        <div style="background:#ff4444; color:#fff; padding:.8rem 1.2rem; border-radius:6px; margin-bottom:1rem; font-size:.88rem; font-weight:500;">
                            @Model.BidError
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.BidSuccess))
                    {
                        <div style="background:#22c55e; color:#fff; padding:.8rem 1.2rem; border-radius:6px; margin-bottom:1rem; font-size:.88rem; font-weight:500;">
                            @Model.BidSuccess
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.LoggedEmail))
                    {
                        <form method="post">
                            <div style="display:flex; gap:.8rem; align-items:flex-end;">
                                <div style="flex:1;">
                                    <label style="font-size:.78rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em; display:block; margin-bottom:.4rem;">Twoja oferta (zł)</label>
                                    <input asp-for="Kwota" type="number" min="1" step="1"
                                           placeholder="np. @((Model.Aukcja.CurrentPrice > 0 ? Model.Aukcja.CurrentPrice + 1 : Model.Aukcja.Price + 1).ToString("N0"))"
                                           class="form-control" />
                                </div>
                                <button type="submit" class="btn-primary-custom" style="white-space:nowrap;">Licytuj</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div style="background:#f5f5f5; border-radius:8px; padding:1.2rem; text-align:center;">
                            <p style="margin:0; font-size:.9rem; color:#666;">Musisz być zalogowany, aby licytować.</p>
                            <a asp-page="/add_user" style="color:var(--orange); font-weight:600; text-decoration:none;">Zaloguj się</a>
                            &nbsp;lub&nbsp;
                            <a asp-page="/register" style="color:var(--orange); font-weight:600; text-decoration:none;">Utwórz konto</a>
                        </div>
                    }
                }
                else
                {
                    <div style="background:#f5f5f5; border-radius:8px; padding:1.2rem; text-align:center; color:#999; font-size:.9rem;">
                        Ta aukcja została zakończona.
                    </div>
                }

                <div style="margin-top:2rem;">
                    <a asp-page="/Index" style="color:#999; font-size:.85rem; text-decoration:none;">← Wróć do aukcji</a>
                </div>
            </div>
        </div>
    }

    <footer>
        <div class="footer-inner">
            <div>
                <div class="footer-logo">Alle<span>drogo</span></div>
                <p>Profesjonalne aukcje od 1996 roku. Kupuj i sprzedawaj z pewnością.</p>
            </div>
            <div class="footer-col">
                <h5>Pomoc</h5>
                <a asp-page="/Regulamin">Regulamin</a>
                <a asp-page="/Prywatnosc">Polityka prywatności</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Alledrogo. Wszelkie prawa zastrzeżone.</span>
            <span>Warszawa, Polska</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
