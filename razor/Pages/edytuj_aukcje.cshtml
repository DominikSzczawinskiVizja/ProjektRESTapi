@page "/edytuj-aukcje/{id:long}"
@model razor.Pages.edytuj_aukcjeModel
@{
    ViewData["Title"] = "Edytuj aukcję";
    var id = RouteData.Values["id"];
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Alledrogo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body>
    <nav>
        <div class="nav-left">
            <a class="nav-logo" href="/">Alle<span>drogo</span></a>
        </div>
        <ul class="nav-links">
            <li><a asp-page="/add_auction">Sprzedaj</a></li>
            @if (!string.IsNullOrEmpty(Model.LoggedEmail))
            {
                <li><span style="color:#ccc; font-size:.82rem; font-weight:500; letter-spacing:.05em; text-transform:uppercase;">@Model.LoggedEmail</span></li>
                <li><a asp-page="/Profil" class="nav-btn" style="background:#333;">Profil</a></li>
                <li><a asp-page="/Logout" class="nav-btn" style="background:#333;">Wyloguj</a></li>
            }
            else
            {
                <li><a asp-page="/register">Utwórz konto</a></li>
                <li><a asp-page="/add_user" class="nav-btn">Zaloguj</a></li>
            }
        </ul>
    </nav>

    <div style="max-width:700px; margin:60px auto; padding:0 1.5rem 80px;">
        <h1 style="font-family:'Bebas Neue',sans-serif; font-size:2.4rem; letter-spacing:1px; margin-bottom:2rem;">Edytuj aukcję</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div style="background:#ff4444; color:#fff; padding:.8rem 1.2rem; border-radius:6px; margin-bottom:1.5rem; font-size:.88rem; font-weight:500;">
                @Model.ErrorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div style="background:#22c55e; color:#fff; padding:.8rem 1.2rem; border-radius:6px; margin-bottom:1.5rem; font-size:.88rem; font-weight:500;">
                @Model.SuccessMessage
            </div>
        }

        <form method="post">
            <div class="mb-4">
                <label class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Nazwa aukcji</label>
                <input asp-for="Nazwa" class="form-control" />
            </div>
            <div class="mb-4">
                <label class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Opis</label>
                <textarea asp-for="Opis" class="form-control" rows="4"></textarea>
            </div>
            <div class="mb-4">
                <label class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Kategoria</label>
                <select asp-for="Kategoria" class="form-control">
                    <option value="Elektronika">Elektronika</option>
                    <option value="Komputery">Komputery</option>
                    <option value="Motoryzacja">Motoryzacja</option>
                    <option value="Dom i ogród">Dom i ogród</option>
                    <option value="Budownictwo">Budownictwo</option>
                    <option value="Narzędzia">Narzędzia</option>
                    <option value="Rolnictwo">Rolnictwo</option>
                    <option value="Sport i hobby">Sport i hobby</option>
                    <option value="Moda">Moda</option>
                    <option value="Przemysł">Przemysł</option>
                </select>
            </div>
            <div class="mb-4">
                <label class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Cena wywoławcza (zł)</label>
                <input asp-for="Cena" type="number" min="1" step="0.01" class="form-control" />
            </div>

            <div style="display:flex; gap:1rem; flex-wrap:wrap; align-items:center;">
                <button type="submit" class="btn-primary-custom">Zapisz zmiany</button>
                <a asp-page="/Index" class="btn-outline-custom" style="display:inline-block;">Anuluj</a>
            </div>
        </form>

        <div style="margin-top:3rem; padding-top:2rem; border-top:1px solid #eee;">
            <h3 style="font-family:'Bebas Neue',sans-serif; font-size:1.4rem; color:#cc2222; margin-bottom:.8rem;">Strefa niebezpieczna</h3>
            <p style="font-size:.88rem; color:#888; margin-bottom:1rem;">Usunięcie aukcji jest nieodwracalne.</p>
            <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Czy na pewno chcesz usunąć tę aukcję?')">
                <button type="submit" style="background:#cc2222; color:#fff; border:none; padding:.7rem 1.8rem; border-radius:4px; font-weight:600; font-size:.88rem; cursor:pointer;">
                    Usuń aukcję
                </button>
            </form>
        </div>
    </div>

    <footer>
        <div class="footer-inner">
            <div>
                <div class="footer-logo">Alle<span>drogo</span></div>
                <p>Profesjonalne aukcje od 1996 roku. Kupuj i sprzedawaj z pewnością.</p>
            </div>
            <div class="footer-col">
                <h5>Pomoc</h5>
                <a asp-page="/Regulamin">Regulamin</a>
                <a asp-page="/Prywatnosc">Polityka prywatności</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Alledrogo. Wszelkie prawa zastrzeżone.</span>
            <span>Warszawa, Polska</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
