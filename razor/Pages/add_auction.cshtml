@page
@model razor.Pages.add_auctionModel
@{
    ViewData["Title"] = "Wystaw przedmiot";
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Alledrogo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav>
        <a class="nav-logo" href="/">Alle<span>drogo</span></a>
        <ul class="nav-links">
            <li><a asp-page="/add_auction">Sprzedaj</a></li>
            <li><a asp-page="/register">Utwórz konto</a></li>
            <li><a asp-page="/add_user" class="nav-btn">Zaloguj</a></li>
        </ul>
    </nav>

    <section class="hero" style="padding: 60px 2rem 50px;">
        <div style="max-width:1200px; margin:0 auto;">
            <div class="hero-tag">Nowa aukcja</div>
            <h1>Wystaw <span>przedmiot</span></h1>
        </div>
    </section>

    <div style="max-width: 520px; margin: 50px auto; padding: 0 1.5rem 0;">
        <form method="post">
            <div class="mb-3">
                <label asp-for="Nazwa" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Nazwa przedmiotu</label>
                <input asp-for="Nazwa" class="form-control" placeholder="np. Laptop Dell XPS 15" />
                <span asp-validation-for="Nazwa" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Kategoria" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Kategoria</label>
                <select asp-for="Kategoria" class="form-control">
                    <option value="">— wybierz kategorię —</option>
                    <option value="elektronika">Elektronika</option>
                    <option value="komputery">Komputery</option>
                    <option value="motoryzacja">Motoryzacja</option>
                    <option value="dom-ogrod">Dom i ogród</option>
                    <option value="budownictwo">Budownictwo</option>
                    <option value="narzedzia">Narzędzia</option>
                    <option value="rolnictwo">Rolnictwo</option>
                    <option value="sport-hobby">Sport i hobby</option>
                    <option value="moda">Moda</option>
                    <option value="przemysl">Przemysł</option>
                </select>
                <span asp-validation-for="Kategoria" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Cenawywoławcza" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Cena wywoławcza (zł)</label>
                <input asp-for="Cenawywoławcza" class="form-control" type="number" min="1" step="1" placeholder="np. 500" />
            </div>

            <div class="mb-4">
                <label asp-for="Czasaukcji" class="form-label" style="font-size:.82rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em;">Czas trwania aukcji</label>
                <select asp-for="Czasaukcji" class="form-control">
                    <option value="12">12 godzin</option>
                    <option value="24" selected>24 godziny</option>
                    <option value="48">48 godzin</option>
                    <option value="72">72 godziny</option>
                </select>
            </div>

            <div style="display:flex; gap:1rem; flex-wrap:wrap;">
                <button type="submit" class="btn-primary-custom">Wystaw aukcję</button>
                <a asp-page="/Index" class="btn-outline-custom" style="display:inline-block;">Anuluj</a>
            </div>
        </form>
    </div>

    <footer>
        <div class="footer-inner">
            <div>
                <div class="footer-logo">Alle<span>drogo</span></div>
                <p>Profesjonalne aukcje od 1996 roku. Kupuj i sprzedawaj z pewnością.</p>
            </div>
            <div class="footer-col">
                <h5>Pomoc</h5>
                <a asp-page="/Regulamin">Regulamin</a>
                <a asp-page="/Prywatnosc">Polityka prywatności</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Alledrogo. Wszelkie prawa zastrzeżone.</span>
            <span>Warszawa, Polska</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
